rules_version = '2';

// ============================================================================
// Reglas de seguridad de Firestore — Pridethink
// ============================================================================
// Reemplazan el modo de prueba (que expira solo y deja todo abierto).
// Principio general: NADA es público. Todo requiere sesión iniciada
// (request.auth != null), y cada acción se limita a lo mínimo que la app
// necesita para funcionar. Cualquier cosa no contemplada aquí queda
// denegada por la regla "catch-all" del final.
//
// Cómo instalar: Firebase console -> Firestore Database -> Reglas -> pegar
// todo este archivo -> Publicar.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Funciones auxiliares reutilizadas por varias colecciones
    // --------------------------------------------------------------------

    // Hay una sesión de Firebase Auth iniciada (cualquier persona registrada).
    function estaAutenticado() {
      return request.auth != null;
    }

    // La persona autenticada es dueña del documento uid (para users/{uid}
    // y notifications/{uid}/...).
    function esDueno(uid) {
      return estaAutenticado() && request.auth.uid == uid;
    }

    // Para reaccionar a un post o a un mensaje de chat: las reacciones se
    // guardan como un mapa { uid: tipo } (ver Reactions.jsx), y esta
    // función valida que la única diferencia entre el mapa de antes y el
    // de después sea la entrada de quien hace la petición (nunca la de
    // otra persona) — y que, si esa entrada quedó presente (agregó o
    // cambió su reacción, no la quitó), su valor sea uno de los 5 tipos
    // válidos. Se reutiliza para posts/{postId} y para
    // chats/{chatId}/messages/{messageId}.
    function soloTocaMiReaccion(antes, despues) {
      let uid = request.auth.uid;
      return despues.diff(antes).affectedKeys().hasOnly([uid])
        && (!(uid in despues) || despues[uid] in ['like', 'applause', 'fire', 'pride', 'funny']);
    }

    // Un chat solo puede ser leído/escrito por sus dos participantes. El id
    // del chat se arma en el código como [uidA, uidB].sort().join("_")
    // (ver getChatId en Chat.jsx), así que separar por "_" siempre recupera
    // los dos uids exactos de la conversación. Los uid de Firebase Auth no
    // contienen "_", así que no hay ambigüedad al separar.
    function esParticipanteDelChat(chatId) {
      return estaAutenticado() && (request.auth.uid in chatId.split('_'));
    }

    // --------------------------------------------------------------------
    // users/{uid}
    // Perfil de cada persona: nombre, identidad, privacidad, a quién
    // bloqueaste (blockedUsers) y a quién sigues (following).
    // --------------------------------------------------------------------
    match /users/{uid} {
      // Cualquier persona con sesión iniciada puede leer cualquier perfil:
      // se necesita para el chat (lista de contactos), el muro (autores),
      // los perfiles públicos, la búsqueda y los contadores de
      // seguidores/seguidos (que se calculan consultando esta colección).
      allow read: if estaAutenticado();

      // Solo la propia persona puede crear o editar su documento
      // (registro inicial, cambiar identidad, privacidad, bloquear a
      // alguien, seguir a alguien). No se restringen campos individuales
      // porque la app actualiza distintos subconjuntos de campos con
      // merge:true (identidad, isPrivate, blockedUsers, following por
      // separado) y siempre sobre tu propio documento — EXCEPTO
      // "isVerified" (badge de cuenta verificada), que es la única
      // excepción a propósito: nadie puede crear su documento con ese
      // campo (no puede llegar en true desde el registro), y ninguna
      // actualización puede cambiar su valor. Es la única forma de que
      // "solo se active a mano desde la consola de Firebase" sea cierto
      // de verdad y no solo "la interfaz no ofrece un botón para esto" —
      // la consola usa el SDK de administrador, que no pasa por estas
      // reglas, así que sigue pudiendo activarlo/desactivarlo sin problema.
      allow create: if esDueno(uid) && !('isVerified' in request.resource.data);
      allow update: if esDueno(uid)
        && request.resource.data.get('isVerified', false) == resource.data.get('isVerified', false);

      // Nadie borra perfiles desde la app.
      allow delete: if false;
    }

    // --------------------------------------------------------------------
    // posts/{postId}  y  posts/{postId}/comments/{commentId}
    // --------------------------------------------------------------------
    match /posts/{postId} {
      // El muro, la búsqueda y los perfiles públicos leen publicaciones.
      allow read: if estaAutenticado();

      // Solo puedes crear una publicación firmada con tu propio uid — y si
      // tiene "groupId" (post de un grupo, ver groups/{groupId} más abajo),
      // solo si sos miembro de ese grupo (Groups.jsx/GroupView.jsx).
      allow create: if estaAutenticado()
        && request.resource.data.authorId == request.auth.uid
        && (
          !('groupId' in request.resource.data)
          || request.resource.data.groupId == null
          || exists(/databases/$(database)/documents/groups/$(request.resource.data.groupId)/members/$(request.auth.uid))
        );

      // Solo el autor puede borrar su publicación.
      allow delete: if estaAutenticado()
        && resource.data.authorId == request.auth.uid;

      // Editar una publicación tiene dos caminos válidos:
      allow update: if estaAutenticado()
        // En ambos casos, nadie puede cambiar quién es el autor del post.
        && resource.data.authorId == request.resource.data.authorId
        && (
          // 1) El autor puede editar cualquier campo suyo (texto, hashtags),
          //    pero no puede mover el post a otro grupo ni sacarlo del suyo
          //    editándolo después de creado ("groupId" queda fijo).
          (
            resource.data.authorId == request.auth.uid
            && request.resource.data.get('groupId', null) == resource.data.get('groupId', null)
          )
          ||
          // 2) Cualquier OTRA persona autenticada puede reaccionar: solo se
          //    le permite tocar el campo "reactions", y solo su propia
          //    entrada dentro de ese mapa (nunca la de alguien más).
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
            && soloTocaMiReaccion(
                 resource.data.get('reactions', {}),
                 request.resource.data.get('reactions', {})
               )
          )
        );

      match /comments/{commentId} {
        // Cualquier autenticado ve los comentarios de cualquier post visible.
        allow read: if estaAutenticado();

        // Solo puedes crear un comentario firmado con tu propio uid.
        allow create: if estaAutenticado()
          && request.resource.data.authorId == request.auth.uid;

        // Solo el autor del comentario puede borrarlo.
        allow delete: if estaAutenticado()
          && resource.data.authorId == request.auth.uid;

        // Hoy la app no permite editar comentarios.
        allow update: if false;
      }
    }

    // --------------------------------------------------------------------
    // chats/{chatId}  y  chats/{chatId}/messages/{messageId}
    // --------------------------------------------------------------------
    match /chats/{chatId} {
      // El documento "padre" del chat (solo guarda participants: [uidA,uidB])
      // solo lo pueden leer y escribir esos dos participantes.
      allow read, write: if esParticipanteDelChat(chatId);

      match /messages/{messageId} {
        // Solo los dos participantes de la conversación ven los mensajes
        // (de texto o nota de voz).
        allow read: if esParticipanteDelChat(chatId);

        // Solo puedes enviar un mensaje si eres participante del chat Y
        // el mensaje queda firmado con tu propio uid como remitente (no
        // puedes mandar un mensaje haciéndote pasar por la otra persona).
        allow create: if esParticipanteDelChat(chatId)
          && request.resource.data.senderId == request.auth.uid;

        // No se puede editar el contenido de un mensaje ya enviado (texto,
        // audio, remitente), pero cualquiera de los dos participantes
        // puede reaccionar: mismo patrón que en posts/{postId}, solo se
        // permite tocar "reactions" y solo la propia entrada del mapa.
        allow update: if esParticipanteDelChat(chatId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
          && soloTocaMiReaccion(
               resource.data.get('reactions', {}),
               request.resource.data.get('reactions', {})
             );

        // Hoy la app no permite borrar mensajes ya enviados.
        allow delete: if false;
      }
    }

    // --------------------------------------------------------------------
    // notifications/{ownerUid}/items/{itemId}
    // --------------------------------------------------------------------
    match /notifications/{ownerUid}/items/{itemId} {
      // Solo el dueño de la bandeja puede leer o borrar sus notificaciones.
      allow read, delete: if esDueno(ownerUid);

      // El dueño puede marcarlas como leídas, pero solo puede tocar el
      // campo "read" (no puede reescribir de qué trataba la notificación).
      allow update: if esDueno(ownerUid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      // Cualquier persona autenticada puede CREAR una notificación para
      // OTRA persona (así funcionan los avisos de like/comentario/mensaje/
      // seguidor nuevo) siempre que la firme con su propio uid como
      // remitente (fromUid) — no puedes notificar en nombre de alguien más.
      allow create: if estaAutenticado()
        && request.resource.data.fromUid == request.auth.uid;
    }

    // --------------------------------------------------------------------
    // savedPosts/{ownerUid}/items/{postId}
    // Lista personal de publicaciones guardadas (SavedPosts.jsx). El
    // documento en sí es solo una referencia — el id del post ES el id del
    // documento, no se copia texto ni autor — así que no hace falta
    // validar ningún campo, solo que sea el dueño de la lista.
    // --------------------------------------------------------------------
    match /savedPosts/{ownerUid}/items/{postId} {
      // Es una lista privada: solo el dueño la lee, agrega o quita
      // referencias. Nadie más puede ver qué guardó otra persona.
      allow read, create, update, delete: if esDueno(ownerUid);
    }

    // --------------------------------------------------------------------
    // groups/{groupId}  y  groups/{groupId}/members/{uid}
    // Grupos/comunidades temáticas (nombre + descripción, sin imagen de
    // portada por ahora). Son públicos: cualquier autenticado los ve y
    // puede unirse — no hay grupos "privados" ni invitación. Los posts de
    // cada grupo viven en la colección posts/{postId} de siempre, con un
    // campo "groupId" (ver el bloque de posts/{postId} más arriba).
    // --------------------------------------------------------------------
    match /groups/{groupId} {
      // Cualquier autenticado ve la lista de grupos y entra a cualquiera.
      allow read: if estaAutenticado();

      // Cualquier autenticado puede crear un grupo, firmado como su propio
      // creador (Groups.jsx también lo suma como primer miembro aparte).
      allow create: if estaAutenticado()
        && request.resource.data.createdBy == request.auth.uid;

      // Todavía no hay forma de editar nombre/descripción una vez creado.
      allow update: if false;

      // Solo quien creó el grupo puede borrarlo.
      allow delete: if estaAutenticado()
        && resource.data.createdBy == request.auth.uid;

      match /members/{uid} {
        // Cualquier autenticado ve quién es miembro (lista de miembros y
        // conteo en vivo, y para saber si un post nuevo respeta la regla
        // de arriba en posts/{postId}).
        allow read: if estaAutenticado();

        // Solo podés agregarte a vos mismo como miembro (unirte).
        allow create: if esDueno(uid);

        // Podés borrarte a vos mismo (salir del grupo), o si sos quien creó
        // el grupo, podés borrar cualquier membresía — así, al eliminar el
        // grupo entero (GroupView.jsx), primero se borran todas las
        // membresías y después el documento del grupo.
        allow delete: if esDueno(uid)
          || get(/databases/$(database)/documents/groups/$(groupId)).data.createdBy == request.auth.uid;

        allow update: if false;
      }
    }

    // --------------------------------------------------------------------
    // events/{eventId}  y  events/{eventId}/attendees/{uid}
    // Eventos (título, descripción, fecha/hora, lugar en texto libre, sin
    // imagen de portada por ahora). Públicos, como los grupos: cualquier
    // autenticado los ve. Todavía no hay función para editar ni borrar un
    // evento (no estaba pedido) — ver Pendientes en CONTEXTO.md.
    // --------------------------------------------------------------------
    match /events/{eventId} {
      // Cualquier autenticado ve la lista de eventos y el detalle de cualquiera.
      allow read: if estaAutenticado();

      // Cualquier autenticado puede crear un evento, firmado como su propio
      // creador.
      allow create: if estaAutenticado()
        && request.resource.data.createdBy == request.auth.uid;

      // Todavía no hay forma de editar ni borrar un evento una vez creado.
      allow update, delete: if false;

      match /attendees/{uid} {
        // Cualquier autenticado ve quién va a asistir (lista de asistentes
        // y conteo en vivo).
        allow read: if estaAutenticado();

        // Solo podés marcarte a vos mismo como asistente ("Asistiré").
        allow create: if esDueno(uid);

        // Solo podés borrar tu propia respuesta ("No asistiré").
        allow delete: if esDueno(uid);

        allow update: if false;
      }
    }

    // --------------------------------------------------------------------
    // reports/{reportId}
    // Reportes de publicaciones o usuarios (moderación). Nadie los lee,
    // edita ni borra desde el cliente: solo se revisan a mano desde la
    // consola de Firebase (que usa el SDK de administrador y no pasa por
    // estas reglas).
    // --------------------------------------------------------------------
    match /reports/{reportId} {
      allow read, update, delete: if false;

      // Cualquier autenticado puede crear un reporte firmado con su propio
      // uid (reporterUid), siempre en estado "pending" (nadie puede crear
      // uno ya resuelto) y sobre un tipo de contenido válido. El id del
      // documento lo arma el cliente como
      // `${reporterUid}_${targetType}_${targetId}` (ver ReportButton.jsx):
      // si esa persona ya reportó ese mismo target, el documento ya existe
      // y Firestore trata el intento como "update" en vez de "create" —
      // como acá no hay `allow update`, se rechaza solo, sin necesitar
      // leer la colección para revisar duplicados de antemano.
      allow create: if estaAutenticado()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.targetType in ["post", "user"];
    }

    // --------------------------------------------------------------------
    // Cualquier otra colección o documento no contemplado arriba:
    // denegado por defecto (mínimo permiso).
    // --------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
